---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import KeyInsights from '../components/KeyInsights.astro';
import PostCard from '../components/PostCard.astro';

type Props = CollectionEntry<'beyond-code'>['data'] & {
	id?: string;
	video?: boolean;
	tags?: string[];
	body?: string;
	relatedPosts?: CollectionEntry<'beyond-code'>[];
	keyInsights?: { number: string; description: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, id, video, tags, body, relatedPosts, keyInsights } = Astro.props;

function readingTime(text: string | undefined): string {
	if (!text) return '1 min';
	const words = text.trim().split(/\s+/).length;
	const minutes = Math.max(1, Math.round(words / 200));
	return `${minutes} min`;
}
---

<html lang={Astro.currentLocale ?? 'en'}>
	<head>
		<script is:inline>
			(function(){try{var p=localStorage.getItem('theme');if(p==='dark'||((!p||p==='system')&&window.matchMedia('(prefers-color-scheme: dark)').matches))document.documentElement.classList.add('dark')}catch(e){}})();
		</script>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"datePublished": pubDate.toISOString(),
			"dateModified": (updatedDate ?? pubDate).toISOString(),
			"author": {
				"@type": "Person",
				"name": "Saulo Vargas",
				"url": "https://rusticit.com"
			},
			"publisher": {
				"@id": "https://rusticit.com/#organization"
			},
			"mainEntityOfPage": new URL(Astro.url.pathname, Astro.site).href
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Home",
					"item": "https://rusticit.com/"
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": "Beyond Code",
					"item": "https://rusticit.com/beyond-code"
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": title
				}
			]
		})} />
	</head>
	<body class="bg-offwhite dark:bg-charcoal min-h-screen">
		<Header />
		<main class="max-w-3xl mx-auto px-4 md:px-8 pt-32 pb-24">
			<article>
				<div class="mb-10 flex flex-col gap-4">
					<a
						href="/beyond-code"
						class="font-mono text-xs text-charcoal/50 dark:text-offwhite/50 uppercase tracking-widest hover:text-crimson transition-colors"
					>
						&larr; Beyond Code
					</a>
					<h1 class="font-heading font-bold text-3xl md:text-5xl tracking-tight text-charcoal dark:text-white leading-tight" transition:name={id ? `title-${id}` : undefined}>
						{title}
					</h1>
					<div class="flex flex-wrap items-center gap-2" transition:name={id ? `date-${id}` : undefined}>
						<span class="font-mono text-[10px] uppercase tracking-widest text-charcoal/50 dark:text-offwhite/50 border border-charcoal/20 dark:border-offwhite/20 rounded-full px-2.5 py-0.5">
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="font-mono text-[10px] uppercase tracking-widest text-charcoal/40 dark:text-offwhite/40 border border-charcoal/15 dark:border-offwhite/15 rounded-full px-2.5 py-0.5 italic">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
						{tags?.map((tag) => (
							<span class="font-mono text-[10px] uppercase tracking-widest text-charcoal/40 dark:text-offwhite/40 border border-charcoal/15 dark:border-offwhite/15 rounded-full px-2.5 py-0.5">
								{tag}
							</span>
						))}
						<span class="font-mono text-[10px] uppercase tracking-widest text-charcoal/40 dark:text-offwhite/40 border border-charcoal/15 dark:border-offwhite/15 rounded-full px-2.5 py-0.5">
							{readingTime(body)}
						</span>
					</div>
				</div>

				{heroImage && !video && (
					<div class="mb-12 overflow-hidden rounded-2xl" transition:name={id ? `hero-${id}` : undefined}>
						<Image width={1020} height={510} src={heroImage} alt={title} class="w-full" />
					</div>
				)}

				{keyInsights && <KeyInsights insights={keyInsights} />}

				<div class="prose">
					<slot />
				</div>
			</article>

			{relatedPosts && relatedPosts.length > 0 && (
				<section class="mt-20 border-t border-charcoal/10 dark:border-offwhite/10 pt-12">
					<h2 class="font-heading font-bold text-xl text-charcoal dark:text-white mb-8 tracking-tight">Related posts</h2>
					<div class="flex flex-col gap-6">
						{relatedPosts.map((rp) => (
							<PostCard post={rp} />
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>