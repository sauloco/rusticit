---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'beyond-code'>['data'] & { id?: string; video?: boolean; tags?: string[]; body?: string };

const { title, description, pubDate, updatedDate, heroImage, id, video, tags, body } = Astro.props;

function readingTime(text: string | undefined): string {
	if (!text) return '1 min';
	const words = text.trim().split(/\s+/).length;
	const minutes = Math.max(1, Math.round(words / 200));
	return `${minutes} min`;
}
---

<html lang={Astro.currentLocale ?? 'en'}>
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-charcoal min-h-screen">
		<Header />
		<main class="max-w-3xl mx-auto px-4 md:px-8 pt-32 pb-24">
			<article>
				<div class="mb-10 flex flex-col gap-4">
					<a
						href="/beyond-code"
						class="font-mono text-xs text-offwhite/50 uppercase tracking-widest hover:text-crimson transition-colors"
					>
						&larr; Beyond Code
					</a>
					<h1 class="font-heading font-bold text-3xl md:text-5xl tracking-tight text-white leading-tight" transition:name={id ? `title-${id}` : undefined}>
						{title}
					</h1>
					<div class="flex flex-wrap items-center gap-2" transition:name={id ? `date-${id}` : undefined}>
						<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/50 border border-offwhite/20 rounded-full px-2.5 py-0.5">
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/40 border border-offwhite/15 rounded-full px-2.5 py-0.5 italic">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
						{tags?.map((tag) => (
							<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/40 border border-offwhite/15 rounded-full px-2.5 py-0.5">
								{tag}
							</span>
						))}
						<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/40 border border-offwhite/15 rounded-full px-2.5 py-0.5">
							{readingTime(body)}
						</span>
					</div>
				</div>

				{heroImage && !video && (
					<div class="mb-12 overflow-hidden rounded-2xl" transition:name={id ? `hero-${id}` : undefined}>
						<Image width={1020} height={510} src={heroImage} alt="" class="w-full" />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	@reference "../styles/global.css";

	.prose {
		@apply font-sans text-offwhite/90 leading-relaxed;
	}
	.prose :global(h2) {
		@apply font-heading font-bold text-2xl text-white mt-12 mb-4;
	}
	.prose :global(h3) {
		@apply font-heading font-semibold text-xl text-white mt-10 mb-3;
	}
	.prose :global(p) {
		@apply mb-6 text-base leading-relaxed;
	}
	.prose :global(a) {
		@apply text-crimson underline underline-offset-2 hover:text-crimson/80 transition-colors;
	}
	.prose :global(code) {
		@apply font-mono text-sm bg-offwhite/10 px-1.5 py-0.5 rounded;
	}
	.prose :global(pre) {
		@apply bg-offwhite/5 border border-offwhite/10 rounded-xl p-4 overflow-x-auto mb-6;
	}
	.prose :global(pre code) {
		@apply bg-transparent p-0;
	}
	.prose :global(blockquote) {
		@apply border-l-4 border-purple-light pl-4 italic text-offwhite/70 my-6;
	}
	.prose :global(ul),
	.prose :global(ol) {
		@apply mb-6 pl-6;
	}
	.prose :global(li) {
		@apply mb-2;
	}
	.prose :global(img) {
		@apply rounded-xl my-8;
	}
	.prose :global(hr) {
		@apply border-offwhite/10 my-10;
	}
</style>