---
import { SITE_TITLE } from "../consts";
import logoDark from "../assets/rustic-logo-dark.svg";
import { Image } from "astro:assets";
const today = new Date();
---

<footer class="bg-charcoal pt-16 pb-8 border-t border-offwhite/10 mt-auto">
    <div
        class="max-w-7xl mx-auto px-4 md:px-16 flex flex-col md:flex-row justify-between items-start md:items-center gap-8"
    >
        <div class="flex flex-col gap-4">
            <a href="/" class="max-w-[120px]">
                <Image
                    src={logoDark}
                    alt={SITE_TITLE}
                    class="opacity-80 hover:opacity-100 transition-opacity"
                />
            </a>
            <p class="font-mono text-xs text-offwhite/50">
                &copy; {today.getFullYear()} RusticIT LLC. All rights reserved.
            </p>
        </div>

        <div class="flex items-center gap-6">
            <a
                href="https://calendly.com/saulovargas"
                target="_blank"
                class="font-sans text-sm text-offwhite/70 hover:text-white transition-colors"
            >
                Book a 20-min intro
            </a>
            <a
                href="https://linkedin.com/in/saulovargas"
                target="_blank"
                class="font-sans text-sm text-offwhite/70 hover:text-white transition-colors"
            >
                LinkedIn
            </a>
        </div>
    </div>
</footer>
