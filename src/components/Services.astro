---
import ButtonCTA from "./ButtonCTA.astro";

const title = `What RusticIT does for B2B SaaS teams`

const services = [
    {
        title: "Frontend Architecture & Stabilization",
        description: "Assess your current frontend, define clear patterns, and stabilize the codebase so new features stop breaking old ones."
    },
    {
        title: "TypeScript Systems that Stay Consistent",
        description: "Set up strong TypeScript conventions, component contracts, and shared utilities so the team stops re-inventing patterns."
    },
    {
        title: "Data-heavy UI Performance",
        description: "Speed up heavy tables, dashboards, and workflows—without rewriting the whole app."
    },
    {
        title: "Modernization & Senior Embed",
        description: "Incremental refactors, migrations, and tooling upgrades. Plug in as a senior engineer who can take ownership and raise frontend quality without hand-holding."
    }
];
---
<section id="services" class="py-24 md:py-32 w-full bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 md:px-16 flex flex-col items-center gap-16">
        <h2 class="font-heading font-bold text-3xl md:text-5xl text-white tracking-tight text-center max-w-2xl">
            {title}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 w-full auto-rows-fr">
            {services.map((service) => (
                <div class="bg-offwhite/5 border border-offwhite/10 p-8 rounded-2xl flex flex-col gap-4 hover:border-purple-light/50 transition-colors">
                    <h3 class="font-sans font-semibold text-xl text-white tracking-tight">{service.title}</h3>
                    <p class="font-sans text-offwhite/70 leading-relaxed text-sm md:text-base">{service.description}</p>
                </div>
            ))}
        </div>
        
    </div>
</section>