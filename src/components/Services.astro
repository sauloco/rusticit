---
import ButtonCTA from "./ButtonCTA.astro";

const title = `What I help B2B SaaS teams improve`
const intro = `I usually work where product complexity, delivery pressure, and frontend quality start colliding.`

const services = [
    {
        title: "Frontend architecture and stabilization",
        description: "Assess the current frontend, identify structural risks, and define practical patterns the team can keep using as the product grows."
    },
    {
        title: "UI systems for complex workflows",
        description: "Design and implement maintainable solutions for dashboards, multi-step flows, permissions, forms, state-heavy interactions, and operational interfaces."
    },
    {
        title: "TypeScript consistency and developer experience",
        description: "Reduce ambiguity across the codebase with stronger contracts, shared utilities, and conventions that make delivery safer and faster."
    },
    {
        title: "Performance for data-heavy products",
        description: "Improve responsiveness in tables, filters, dashboards, and workflow-heavy screens without jumping straight into a rewrite."
    },
    {
        title: "Senior embedded execution",
        description: "Plug directly into the team to ship improvements, unblock delivery, and raise frontend quality while working within the reality of an existing product."
    }
];
---
<section id="services" class="py-24 md:py-32 w-full bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 md:px-16 flex flex-col items-center gap-8">
        <div class="flex flex-col gap-4 max-w-3xl text-center">
            <h2 class="font-heading font-bold text-3xl md:text-5xl text-white tracking-tight">
                {title}
            </h2>
            <p class="font-sans text-xl text-offwhite/70 leading-relaxed">
                {intro}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 w-full auto-rows-fr mt-8">
            {services.map((service) => (
                <div class="bg-offwhite/5 border border-offwhite/10 p-8 rounded-2xl flex flex-col gap-4 hover:border-purple-light/50 transition-colors">
                    <h3 class="font-sans font-semibold text-xl text-white tracking-tight">{service.title}</h3>
                    <p class="font-sans text-offwhite/70 leading-relaxed text-sm md:text-base">{service.description}</p>
                </div>
            ))}
        </div>

    </div>
</section>
