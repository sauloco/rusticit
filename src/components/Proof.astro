---
import {Testimonial} from '@components/ui/clean-testimonial';
import danteAvatar from '../assets/testimonials/dante-gallina.png';
import rowinAvatar from '../assets/testimonials/rowin-hernandez.png';
import martinAvatar from '../assets/testimonials/martin-soncini.png';
import darioAvatar from '../assets/testimonials/dario-schmidt.png';
import nataliaAvatar from '../assets/testimonials/natalia-gelmi.png';

const testimonials = [
    {
        quote: 'Saulo is a rare kind of engineer: fast to understand, strong in decision-making, and consistently reliable in delivery. He brings real craft to complex products and executes with very little oversight.',
        author: 'Rowin Hernandez',
        role: 'Lead Engineer',
        company: 'Synphonyte',
        avatar: rowinAvatar.src,
    },
    {
        quote: 'Saulo is a committed and trustworthy professional. In a highly demanding health records project, he brought technical clarity, concrete solutions, strong collaboration, and a consistent focus on improving the user experience.',
        author: 'Natalia Gelmi',
        role: 'Digital Government Coordinator',
        company: 'Muncipality of Olavarría',
        avatar: nataliaAvatar.src
    },
    {
        quote: 'Saulo had a lasting impact on my development journey. He combines strong experience with a rare ability to teach, guide, and help the people around him grow.',
        author: 'Martín Soncini',
        role: 'Frontend Developer',
        company: 'Uteam',
        avatar: martinAvatar.src,
    },
    {
        quote: 'Saulo combines technical depth with strong communication and sound judgment. He understands problems deeply, proposes practical solutions, and helps move projects forward with clarity.',
        author: 'Darío Schmidt',
        role: 'PM',
        company: 'COCO',
        avatar: darioAvatar.src,
    },
    {
        quote: 'Saulo is a versatile, reliable, and highly committed professional. He leads with ownership, works well across teams, and brings the kind of consistency companies can trust.',
        author: 'Dante Gallina',
        role: 'CEO',
        company: 'DLG Sistemas & Asoc.',
        avatar: danteAvatar.src,
    },
];
---

<section id="proof" class="relative z-30 bg-charcoal testimonial-section w-full py-16 px-4 overflow-hidden">
    <div class="max-w-4xl mx-auto text-center mb-8">
        <h2 class="font-heading font-bold text-4xl md:text-5xl text-offwhite leading-tight">
            Trusted by teams that needed senior execution
        </h2>
    </div>

    <Testimonial
            client:visible
            testimonials={testimonials}
    />
</section>
