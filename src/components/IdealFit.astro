---
const title = "Who I work best with";

const greatFit = [
    "You already have a live B2B product",
    "Your frontend is getting harder to scale cleanly",
    "Your product has dashboards, workflows, forms, permissions, or heavy UI logic",
    "You want senior-level support without committing to a full-time hire yet",
    "You need someone who can work inside complexity without creating more of it"
];

const notAFit = [
    "You only need a marketing site or brochure website",
    "You want the cheapest delivery option",
    "You need a large agency model with multiple layers",
    "You want to outsource product thinking completely"
];
---

<section id="ideal-fit" class="relative z-30 py-24 md:py-32 w-full bg-charcoal/5 dark:bg-offwhite/5 border-t border-b border-charcoal/5 dark:border-offwhite/5 overflow-hidden backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-4 md:px-16">
        <h2 class="font-heading font-bold text-3xl md:text-5xl text-charcoal dark:text-white mb-16 tracking-tight text-center">
            {title}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 max-w-5xl mx-auto">

            <div class="flex flex-col gap-6 bg-offwhite dark:bg-charcoal/50 border border-charcoal/10 dark:border-offwhite/10 p-8 rounded-3xl">
                <div class="flex items-center gap-3 border-b border-charcoal/10 dark:border-offwhite/10 pb-4">
                    <div class="w-8 h-8 rounded-full bg-purple-dark/20 dark:bg-purple-dark/30 flex items-center justify-center text-purple-light font-bold">✓</div>
                    <h3 class="font-sans font-semibold text-xl text-charcoal dark:text-white">Great fit if:</h3>
                </div>

                <ul class="flex flex-col gap-4 mt-2">
                    {greatFit.map(item => (
                        <li class="flex items-start gap-3 text-charcoal/80 dark:text-offwhite/80 font-sans">
                            <span class="text-purple-light mt-1 text-sm font-bold">→</span>
                            <span class="leading-relaxed">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>

            <div class="flex flex-col gap-6 bg-offwhite dark:bg-charcoal/50 border border-charcoal/10 dark:border-offwhite/10 p-8 rounded-3xl opacity-80">
                <div class="flex items-center gap-3 border-b border-charcoal/10 dark:border-offwhite/10 pb-4">
                    <div class="w-8 h-8 rounded-full bg-offwhite dark:bg-charcoal flex items-center justify-center text-charcoal/50 dark:text-offwhite/50 font-bold border border-charcoal/10 dark:border-offwhite/10">✕</div>
                    <h3 class="font-sans font-semibold text-xl text-charcoal/80 dark:text-offwhite/80">Probably not the right fit:</h3>
                </div>

                <ul class="flex flex-col gap-4 mt-2">
                    {notAFit.map(item => (
                        <li class="flex items-start gap-3 text-charcoal/60 dark:text-offwhite/60 font-sans">
                            <span class="text-charcoal/30 dark:text-offwhite/30 mt-1 text-xs">■</span>
                            <span class="leading-relaxed">{item}</span>
                        </li>
                    ))}
                </ul>
            </div>

        </div>
    </div>
</section>
