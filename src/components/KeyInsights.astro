---
import CountUp from './vue/bits/CountUp/CountUp.vue';

interface Insight {
	number: string;
	description: string;
}

interface Props {
	insights: Insight[];
}

const { insights } = Astro.props;

const isValid =
	insights &&
	insights.length === 3 &&
	insights.every((i) => i.number !== undefined && i.number !== '' && i.description);

if (!isValid) return;

const gradients = [
	'from-[#4a2d7a] to-[#3b4d9e]',
	'from-[#3b4d9e] to-[#6b2d6e]',
	'from-[#6b2d6e] to-[#8b2040]',
];

function parseCountUp(raw: string): { from: number; to: number; suffix: string; separator: string; isStatic: boolean } {
	const cleaned = raw.replace(/,/g, '');
	const match = cleaned.match(/^([0-9]+)(.*)/);
	if (!match) return { from: 0, to: 0, suffix: raw, separator: '', isStatic: true };

	const num = parseInt(match[1], 10);
	const suffix = match[2] || '';

	if (num === 0) return { from: 0, to: 0, suffix, separator: '', isStatic: true };

	const needsSeparator = num >= 1000;
	const from = num > 1000 ? Math.round(num * 0.88) : 0;

	return { from, to: num, suffix, separator: needsSeparator ? ',' : '', isStatic: false };
}

const cards = insights.map((insight, i) => ({
	...insight,
	gradient: gradients[i],
	countUp: parseCountUp(insight.number),
}));

const durations = [1.4, 1.0, 0.6];
---

<div class="not-prose my-12 grid grid-cols-1 sm:grid-cols-3 gap-4">
	{cards.map((card, i) => (
		<div
			class={`relative overflow-hidden rounded-2xl bg-gradient-to-r ${card.gradient} p-6 flex flex-col justify-between min-h-[120px]`}
			data-reveal="fade-up"
			data-reveal-delay={String(i * 100)}
		>
			<span class="font-sans text-sm text-white/80 tracking-wide">
				{card.description}
			</span>
			<span class="mt-3 text-right font-heading font-bold text-4xl md:text-5xl text-white leading-none">
				{card.countUp.isStatic ? (
					<span>{card.countUp.to}{card.countUp.suffix}</span>
				) : (
					<span>
						<CountUp
							client:visible
							from={card.countUp.from}
							to={card.countUp.to}
							duration={durations[i]}
							separator={card.countUp.separator}
						/>{card.countUp.suffix}
					</span>
				)}
			</span>
		</div>
	))}
</div>
