---
const title = "When frontend complexity grows, delivery usually slows down in predictable ways";
const intro = `Most teams don't need "more frontend." They need fewer bottlenecks, clearer patterns, and a codebase that doesn't fight every new feature.`;
const closingLine = "I focus on the root causes behind those issues so your team can ship with more confidence and less rework.";

const problems = [
    {
        title: "Architecture starts working against the team",
        description: "New features take longer, shared components become risky, and each sprint creates more coupling."
    },
    {
        title: "Patterns are inconsistent across the app",
        description: "Different engineers solve similar problems in different ways, which increases bugs, friction, and review time."
    },
    {
        title: "UI complexity keeps compounding",
        description: "Forms, permissions, states, edge cases, and workflow logic pile up until simple changes stop feeling simple."
    },
    {
        title: "Data-heavy screens become slow and fragile",
        description: "Dashboards, tables, filters, and operational workflows start hurting usability and engineering velocity at the same time."
    },
    {
        title: "Technical debt blocks delivery",
        description: "The team knows where the problems are, but fixing them keeps getting postponed because shipping pressure never stops."
    }
];
---

<section id="problem" class="py-24 md:py-32 max-w-7xl mx-auto px-4 md:px-16 flex flex-col items-center">
    <div class="max-w-4xl w-full">
        <h2 class="font-heading font-bold text-3xl md:text-5xl text-white mb-6 tracking-tight text-center">
            {title}
        </h2>

        <p class="font-sans text-xl text-offwhite/70 leading-relaxed text-center mb-16 max-w-3xl mx-auto">
            {intro}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 auto-rows-fr">
            {problems.map((problem) => (
                <div class="bg-charcoal border border-offwhite/10 p-8 rounded-2xl flex flex-col gap-3 hover:border-crimson/50 transition-colors">
                    <h3 class="font-sans font-semibold text-xl text-offwhite">{problem.title}</h3>
                    <p class="font-sans text-offwhite/70 text-base">{problem.description}</p>
                </div>
            ))}
            <div class="bg-gradient-to-br from-charcoal to-purple-dark border border-offwhite/10 p-8 rounded-2xl flex flex-col gap-3 hover:border-purple-light/50 transition-colors">
                <span class="text-crimson text-2xl font-bold shrink-0">→</span>
                <p class="font-sans text-lg md:text-xl text-white font-medium leading-relaxed">
                    {closingLine}
                </p>
            </div>
        </div>
    </div>
</section>
