---
const title = "Where B2B SaaS frontend teams usually get stuck";
const intro = `When delivery slows down, the problem is rarely "more frontend work." It's usually architecture, inconsistent patterns, and product complexity compounding over time.`;
const summary = "I help teams standardize patterns, simplify frontend structure, untangle complex product surfaces, and improve performance where complexity shows up fastest.";

const cards = [
    {
        title: "Inconsistent patterns across the app",
        body: "Similar problems get solved in different ways, increasing bugs, friction, and review time."
    },
    {
        title: "Architecture starts working against delivery",
        body: "Shared components become risky, coupling grows, and each sprint makes the codebase harder to change."
    },
    {
        title: "UI complexity keeps compounding",
        body: "Forms, permissions, state, and workflow logic pile up until simple changes stop feeling simple."
    },
    {
        title: "Data-heavy screens become slow and fragile",
        body: "Dashboards, tables, and filters start hurting usability and engineering speed at the same time."
    }
];
---

<section id="problem" class="relative py-20 w-full md:py-28 mx-auto px-4 md:px-16 flex flex-col items-center z-100 bg-charcoal">
    <div class="max-w-7xl w-full">
        <h2 class="font-heading font-bold text-3xl md:text-5xl text-white mb-6 tracking-tight text-center">
            {title}
        </h2>

        <p class="font-sans text-xl text-offwhite/70 leading-relaxed text-center mb-12 max-w-4xl mx-auto">
            {intro}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-5 md:gap-6">
            {cards.map((card, i) => (
                <div
                    data-reveal="fade-down"
                    data-reveal-delay={String(i * 120)}
                    class="bg-charcoal border border-offwhite/10 px-7 py-6 rounded-2xl flex flex-col gap-3 hover:border-offwhite/25 transition-colors"
                >
                    <h3 class="font-sans font-semibold text-lg text-offwhite">{card.title}</h3>
                    <p class="font-sans text-offwhite/60 text-base leading-relaxed">{card.body}</p>
                </div>
            ))}
        </div>

        <p
            data-reveal="fade-up"
            class="font-sans text-lg text-offwhite/50 leading-relaxed text-center mt-10 max-w-3xl mx-auto"
        >
            {summary}
        </p>
    </div>
</section>