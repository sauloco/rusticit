---
const title = "If your frontend is slowing you down, it’s usually one of these";
const closingLine = "RusticIT focuses on fixing the root causes—so your team ships faster with fewer surprises.";

const problems = [
    {
        title: "Architecture doesn't scale",
        description: "Features get harder every sprint"
    },
    {
        title: "TypeScript inconsistency",
        description: "Patterns vary by engineer → bugs + friction"
    },
    {
        title: "Technical debt pile-up",
        description: "Small changes take days"
    },
    {
        title: "Performance issues",
        description: "Data-heavy screens feel sluggish"
    },
    {
        title: "UI complexity",
        description: "Forms, permissions, state, and edge cases explode"
    }
];
---

<section id="problem" class="py-24 md:py-32 max-w-7xl mx-auto px-4 md:px-16 flex flex-col items-center">
    <div class="max-w-4xl w-full">
        <h2 class="font-heading font-bold text-3xl md:text-5xl text-white mb-16 tracking-tight text-center">
            {title}
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 auto-rows-fr">
            {problems.map((problem) => (
                <div class="bg-charcoal border border-offwhite/10 p-8 rounded-2xl flex flex-col gap-3 hover:border-crimson/50 transition-colors">
                    <h3 class="font-sans font-semibold text-xl text-offwhite">{problem.title}</h3>
                    <p class="font-sans text-offwhite/70 text-base">{problem.description}</p>
                </div>
            ))}
        </div>
        
        <div class="mt-16 text-center">
            <p class="font-sans text-xl md:text-2xl text-offwhite/90 font-medium">
                {closingLine}
            </p>
        </div>
    </div>
</section>
