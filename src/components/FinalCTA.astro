---
import ButtonCTA from "./ButtonCTA.astro";
const title = "Need senior frontend support for a product that's getting harder to ship?";
const body = "If frontend complexity is starting to slow delivery, I can help you identify the main bottlenecks and work on the fixes that actually improve velocity, quality, and maintainability.";
const supportingLine = "I'll reply personally and let you know quickly whether I'm the right fit.";
---

<section id="final-cta" class="py-32 w-full bg-charcoal text-center">
    <div class="max-w-4xl mx-auto px-4 md:px-16 flex flex-col items-center gap-10">

        <h2 class="font-heading font-bold text-4xl md:text-5xl text-white tracking-tight leading-tight">
            {title}
        </h2>

        <p class="font-sans text-xl text-offwhite/80 leading-relaxed max-w-3xl">
            {body}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-4 w-full sm:w-auto">
            <ButtonCTA fullWidth magnetic location="final-cta" />
            <a href="mailto:hello@rusticit.com" class="inline-flex items-center justify-center px-8 py-4 text-base font-medium tracking-wide text-offwhite transition-all bg-offwhite/5 rounded-md hover:bg-offwhite/10 ring-1 ring-inset ring-offwhite/20 font-sans w-full sm:w-fit">
                Email me directly
            </a>
        </div>

        <p class="font-mono text-sm text-offwhite/50 tracking-wide">
            {supportingLine}
        </p>

        <a href="/beyond-code" class="font-sans text-sm text-offwhite/40 hover:text-offwhite/70 transition-colors underline underline-offset-2">
            Prefer reading first? Visit the blog
        </a>

    </div>
</section>
