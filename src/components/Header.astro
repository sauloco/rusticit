---
import { Image } from "astro:assets";
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ButtonCTA from "./ButtonCTA.astro";
import logoDark from "../assets/rustic-logo-dark.svg";
import logoLight from "../assets/rustic-logo-light.svg";
import ThemeToggle from "./ThemeToggle.astro";

const links = [
    { href: "/#services", label: "Services" },
    { href: "/#work", label: "Case Studies" },
    { href: "/#how-we-work", label: "How I Work" },
    { href: "/#about", label: "About" },
    { href: "/#contact", label: "Contact" },
];
---

<!-- Desktop navbar -->
<div class="fixed w-full z-50">
<header
    class="absolute left-1/2 -translate-x-1/2 hidden md:block md:min-w-[600px] w-max px-6 py-3 animate-fade-in-down animate-delay-100 bg-offwhite/80 hover:bg-offwhite dark:bg-charcoal/80 dark:hover:bg-charcoal transition-all rounded-full z-[1000] my-6 backdrop-blur-md shadow-lg border border-charcoal/10 dark:border-offwhite/10"
>
    <nav class="flex gap-8 flex-row justify-between items-center">
        <a href="/#" class="max-w-[100px]" aria-label="RusticIT homepage">
            <Image src={logoLight} alt={SITE_TITLE} class="dark:hidden" />
            <Image src={logoDark} alt={SITE_TITLE} class="hidden dark:block" />
        </a>
        <div class="flex flex-row gap-6 items-center text-sm font-sans font-medium">
            {links.map((link) => (
                <HeaderLink
                    href={link.href}
                    class="text-charcoal/80 hover:text-charcoal dark:text-offwhite/80 dark:hover:text-white transition-colors"
                >
                    {link.label}
                </HeaderLink>
            ))}
        </div>
        <div class="flex items-center gap-3 animate-fade-in-right animate-delay-100">
            <ButtonCTA size="sm" magnetic location="navbar" />
        </div>
    </nav>
</header>

<ThemeToggle className="fixed right-4 mt-9"/>

</div>
<!-- Mobile navbar -->
<header
    id="mobile-header"
    class="fixed top-0 left-0 right-0 md:hidden z-[1000] animate-fade-in-down animate-delay-100"
>
    <div class="mobile-nav-bar bg-offwhite/90 dark:bg-charcoal/90 backdrop-blur-md border-b border-charcoal/10 dark:border-offwhite/10 px-4 py-3">
        <!-- Top row: logo + theme toggle + hamburger -->
        <div class="flex items-center justify-between">
            <a href="/#" class="max-w-[100px]" aria-label="RusticIT homepage">
                <Image src={logoLight} alt={SITE_TITLE} class="dark:hidden" />
                <Image src={logoDark} alt={SITE_TITLE} class="hidden dark:block" />
            </a>
            <div class="flex items-center gap-2">
                <ThemeToggle />
                <button
                id="mobile-menu-btn"
                type="button"
                class="relative w-10 h-10 flex items-center justify-center text-charcoal/80 hover:text-charcoal dark:text-offwhite/80 dark:hover:text-white transition-colors"
                aria-label="Toggle menu"
                aria-expanded="false"
            >
                <!-- Hamburger icon -->
                <svg
                    id="icon-open"
                    class="w-6 h-6 transition-all duration-300"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <line x1="4" y1="6" x2="20" y2="6" />
                    <line x1="4" y1="12" x2="20" y2="12" />
                    <line x1="4" y1="18" x2="20" y2="18" />
                </svg>
                <!-- Close icon -->
                <svg
                    id="icon-close"
                    class="w-6 h-6 absolute transition-all duration-300 opacity-0 scale-75"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <line x1="6" y1="6" x2="18" y2="18" />
                    <line x1="6" y1="18" x2="18" y2="6" />
                </svg>
            </button>
            </div>
        </div>

        <!-- Expandable menu links -->
        <nav
            id="mobile-menu"
            class="grid transition-[grid-template-rows] duration-500 ease-out"
            style="grid-template-rows: 0fr;"
        >
            <div class="overflow-hidden">
                <div class="flex flex-col gap-1 pt-4 pb-2">
                    {links.map((link, i) => (
                        <a
                            href={link.href}
                            class="mobile-nav-link text-charcoal/80 hover:text-charcoal dark:text-offwhite/80 dark:hover:text-white text-lg font-sans font-medium py-3 px-2 rounded-lg hover:bg-charcoal/5 dark:hover:bg-offwhite/5 transition-all opacity-0 translate-y-2"
                            style={`transition-delay: ${i * 75}ms;`}
                        >
                            {link.label}
                        </a>
                    ))}
                    <span
                        class="mobile-nav-link mt-3 opacity-0 translate-y-2"
                        style={`transition-delay: ${links.length * 75}ms;`}
                    >
                        <ButtonCTA size="sm" location="navbar" />
                    </span>
                </div>
            </div>
        </nav>
    </div>
</header>

<!-- Backdrop overlay -->
<div
    id="mobile-backdrop"
    class="fixed inset-0 bg-offwhite/60 dark:bg-charcoal/60 backdrop-blur-sm z-[999] opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"
></div>

<script>
    function initMobileMenu() {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const backdrop = document.getElementById("mobile-backdrop");
        const iconOpen = document.getElementById("icon-open");
        const iconClose = document.getElementById("icon-close");
        const navLinks = document.querySelectorAll<HTMLElement>(".mobile-nav-link");

        if (!btn || !menu || !backdrop || !iconOpen || !iconClose) return;

        let isOpen = false;

        function toggle() {
            isOpen = !isOpen;
            btn!.setAttribute("aria-expanded", String(isOpen));

            menu!.style.gridTemplateRows = isOpen ? "1fr" : "0fr";

            iconOpen!.style.opacity = isOpen ? "0" : "1";
            iconOpen!.style.transform = isOpen ? "scale(0.75) rotate(90deg)" : "scale(1) rotate(0)";
            iconClose!.style.opacity = isOpen ? "1" : "0";
            iconClose!.style.transform = isOpen ? "scale(1) rotate(0)" : "scale(0.75) rotate(-90deg)";

            backdrop!.style.opacity = isOpen ? "1" : "0";
            backdrop!.style.pointerEvents = isOpen ? "auto" : "none";

            navLinks.forEach((link) => {
                if (isOpen) {
                    link.style.opacity = "1";
                    link.style.transform = "translateY(0)";
                } else {
                    link.style.opacity = "0";
                    link.style.transform = "translateY(0.5rem)";
                }
            });
        }

        btn.addEventListener("click", toggle);
        backdrop.addEventListener("click", toggle);

        navLinks.forEach((link) => {
            link.addEventListener("click", () => {
                if (isOpen) toggle();
            });
        });
    }

    document.addEventListener("astro:page-load", initMobileMenu);
</script>

<style>
    .mobile-nav-link {
        transition-property: opacity, transform, background-color, color;
        transition-duration: 400ms, 400ms, 200ms, 200ms;
        transition-timing-function: ease-out;
    }
</style>
