---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('beyond-code', (post) => !post.data.private)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allYears = [...new Set(posts.map((p) => p.data.pubDate.getFullYear()))].sort((a, b) => b - a);
const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))].sort();

function readingTime(body: string | undefined): string {
	if (!body) return '1 min';
	const words = body.trim().split(/\s+/).length;
	const minutes = Math.max(1, Math.round(words / 200));
	return `${minutes} min`;
}
---

<!doctype html>
<html lang={Astro.currentLocale ?? 'en'}>
	<head>
		<BaseHead title={`Beyond Code — ${SITE_TITLE}`} description="Thoughts on frontend engineering, product thinking, and the craft behind real-world software." />
	</head>
	<body class="bg-charcoal min-h-screen">
		<Header />
		<main class="max-w-4xl mx-auto px-4 md:px-8 pt-32 pb-24">
			<div class="flex flex-col gap-4 mb-16">
				<h1 class="font-heading font-bold text-4xl md:text-5xl tracking-tight text-white">
					Beyond Code
				</h1>
				<p class="font-sans text-lg text-offwhite/70 leading-relaxed max-w-2xl">
					Thoughts on frontend engineering, product thinking, and the craft behind real-world software.
				</p>
				<p class="font-sans text-lg text-offwhite/70 leading-relaxed max-w-2xl">
					No AI slop.
				</p>
			</div>

			<!-- Filters -->
			<div class="flex flex-col gap-4 mb-8">
				<div class="flex flex-wrap gap-2 items-center">
					<button data-filter="all" class="filter-btn active font-mono text-xs uppercase tracking-widest text-white border border-offwhite/30 bg-offwhite/10 rounded-full px-3 py-1 transition-colors">
						All
					</button>
					{allYears.map((year) => (
						<button data-filter="year" data-value={year} class="filter-btn font-mono text-xs uppercase tracking-widest text-offwhite/50 border border-offwhite/20 rounded-full px-3 py-1 hover:text-white hover:border-offwhite/40 transition-colors">
							{year}
						</button>
					))}
					<span class="w-px h-4 bg-offwhite/20 mx-1"></span>
					{allTags.map((tag) => (
						<button data-filter="tag" data-value={tag} class="filter-btn font-mono text-xs uppercase tracking-widest text-offwhite/50 border border-offwhite/20 rounded-full px-3 py-1 hover:text-white hover:border-offwhite/40 transition-colors">
							{tag}
						</button>
					))}
				</div>
				<p id="post-count" class="font-mono text-xs text-offwhite/40">
					{posts.length} articles
				</p>
			</div>

			<div class="flex flex-col gap-6" id="posts-list">
				{posts.map((post) => (
					<a
						href={`/beyond-code/${post.id}/`}
						class="post-card group flex flex-col md:flex-row gap-6 rounded-2xl border border-offwhite/10 bg-offwhite/5 p-6 hover:bg-offwhite/10 transition-colors duration-300"
						data-year={post.data.pubDate.getFullYear()}
						data-tags={JSON.stringify(post.data.tags ?? [])}
					>
						{post.data.heroImage && (
							<div class="md:w-48 md:h-32 flex-shrink-0 overflow-hidden rounded-xl" transition:name={`hero-${post.id}`}>
								<Image
									width={384}
									height={256}
									src={post.data.heroImage}
									alt=""
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
								/>
							</div>
						)}
						<div class="flex flex-col gap-2 justify-center">
							<div class="flex flex-wrap gap-2 items-center" transition:name={`date-${post.id}`}>
								<span class="font-mono text-[10px] uppercase tracking-widest text-crimson font-bold border border-crimson/30 rounded-full px-2.5 py-0.5">
									<FormattedDate date={post.data.pubDate} />
								</span>
								{post.data.tags?.map((tag: string) => (
									<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/50 border border-offwhite/20 rounded-full px-2.5 py-0.5">
										{tag}
									</span>
								))}
								<span class="font-mono text-[10px] uppercase tracking-widest text-offwhite/40 border border-offwhite/15 rounded-full px-2.5 py-0.5">
									{readingTime(post.body)}
								</span>
							</div>
							<h2 class="font-sans font-semibold text-xl text-white group-hover:text-crimson transition-colors" transition:name={`title-${post.id}`}>
								{post.data.title}
							</h2>
							<p class="font-sans text-sm text-offwhite/60 leading-relaxed line-clamp-2">
								{post.data.description}
							</p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	document.addEventListener('astro:page-load', () => {
		const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
		const cards = document.querySelectorAll<HTMLElement>('.post-card');
		const countEl = document.getElementById('post-count');

		function updateCount() {
			const visible = document.querySelectorAll('.post-card:not([hidden])').length;
			if (countEl) countEl.textContent = `${visible} article${visible !== 1 ? 's' : ''}`;
		}

		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				buttons.forEach((b) => {
					b.classList.remove('active', 'text-white', 'border-offwhite/30', 'bg-offwhite/10');
					b.classList.add('text-offwhite/50', 'border-offwhite/20');
				});
				btn.classList.add('active', 'text-white', 'border-offwhite/30', 'bg-offwhite/10');
				btn.classList.remove('text-offwhite/50', 'border-offwhite/20');

				const filter = btn.dataset.filter;
				const value = btn.dataset.value;

				cards.forEach((card) => {
					if (filter === 'all') {
						card.hidden = false;
					} else if (filter === 'year') {
						card.hidden = card.dataset.year !== value;
					} else if (filter === 'tag') {
						const tags: string[] = JSON.parse(card.dataset.tags || '[]');
						card.hidden = !tags.includes(value!);
					}
				});

				updateCount();
			});
		});
	});
</script>