---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Services from "../components/Services.astro";
import SelectedWork from "../components/SelectedWork.astro";
import HowWeWork from "../components/HowWeWork.astro";
import IdealFit from "../components/IdealFit.astro";
import About from "../components/About.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Base from "../layouts/Base.astro";
import GradualBlur from "@components/vue/bits/GradualBlur/GradualBlur.vue";
---
<Base>
    <Hero/>
    <Problem />
    <Services />
    <SelectedWork />
    <HowWeWork />
    <IdealFit />
    <About />
    <FinalCTA />
    <Footer />

    <!-- Fixed bottom blur that dissolves near the footer -->
    <div id="page-blur-wrapper" class="fixed bottom-0 left-0 right-0 z-[1000] pointer-events-none transition-opacity duration-500">
        <GradualBlur
            client:load
            position="bottom"
            height="8rem"
            strength={3}
            curve="ease-out"
            divCount={6}
            target="parent"
            style={{ position: 'relative' }}
        />
    </div>
</Base>

<script>
    document.addEventListener('astro:page-load', () => {
        const wrapper = document.getElementById('page-blur-wrapper');
        const footer = document.querySelector('footer');

        if (wrapper && footer) {
            const thresholds = Array.from({ length: 21 }, (_, i) => i / 20);
            const observer = new IntersectionObserver(
                ([entry]) => {
                    const opacity = Math.max(0, 1 - entry.intersectionRatio * 4);
                    wrapper.style.opacity = String(opacity);
                },
                { threshold: thresholds }
            );
            observer.observe(footer);
        }
    });
</script>